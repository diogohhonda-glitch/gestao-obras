# ── Servidor ──────────────────────────────────────────
PORT=3002
BASE_URL=http://localhost:3002
JWT_SECRET=mude-esta-chave-secreta

# ── Asaas (pagamento Pix) ─────────────────────────────
# Sandbox:    https://sandbox.asaas.com  → crie conta grátis em asaas.com
# Produção:   ASAAS_ENV=prod
ASAAS_ENV=sandbox
ASAAS_KEY=$aact_SEU_TOKEN_AQUI

# Chave Pix fallback (quando Asaas não estiver configurado)
PIX_KEY=diogo.hhonda@gmail.com

# ── E-mail (opcional) ─────────────────────────────────
# Gmail: use senha de aplicativo em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-senha-de-aplicativo
